     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "a1 = cp.Variable()\n",
    "a2 = cp.Variable()\n",
    "\n",
    "constraints = [a1 * 8 + a2 * 2 <= 365, \n",
    "               a1 * 23 + a2 * 5 <= 500]\n",
    "\n",
    "obj = cp.Maximize(a1 * 10 + a2 * 3)\n",
    "prob = cp.Problem(obj, constraints)\n",
    "prob.solve()"
   ]
  }
